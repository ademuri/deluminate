{
  "type": "module",
  "name": "deluminate",
  "version": "1.1.3",
  "description": "Invert the luminance of a website to make it easier on the eyes.",
  "scripts": {
    "lint": "eslint *.js",
    "format": "prettier --write .",
    "test": "c8 mocha 'spec/**/*.js'",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "package": "zip -r deluminate.zip . -x '*.git*' -x 'node_modules/*' -x 'spec/*' -x '*.zip' -x 'deploy*' -x 'pw-browsers*' -x 'coverage*' -x 'test-results*' -x '.npm-cache*' -x '.vscode*' -x 'e2e*' -x '.gemini*'",
    "deploy": "npm run package && ./deploy deluminate.zip --release",
    "deploy-dev": "npm run package && ./deploy deluminate.zip"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ademuri/deluminate.git"
  },
  "keywords": [
    "chrome",
    "extension",
    "invert",
    "luminance",
    "dark",
    "contrast"
  ],
  "contributors": [
    {
      "name": "Anjou Stiles"
    },
    {
      "name": "Adam DeMuri"
    }
  ],
  "license": "BSD-2-Clause",
  "bugs": {
    "url": "https://github.com/ademuri/deluminate/issues"
  },
  "homepage": "https://github.com/ademuri/deluminate",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@playwright/test": "^1.58.2",
    "c8": "^10.1.3",
    "chrome-webstore-upload-cli": "^3.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "expect": "^30.3.0",
    "globals": "^17.4.0",
    "jsdom": "^24.1.1",
    "mocha": "^11.3.0",
    "mock-local-storage": "^1.0.2",
    "prettier": "^3.8.1"
  },
  "jshintConfig": {
    "esversion": 13,
    "browser": true,
    "loopfunc": true,
    "laxbreak": true,
    "laxcomma": true,
    "sub": true,
    "asi": true,
    "expr": true,
    "eqnull": true,
    "-W032": true,
    "-W041": true
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "webextensions": true
    }
  }
}
